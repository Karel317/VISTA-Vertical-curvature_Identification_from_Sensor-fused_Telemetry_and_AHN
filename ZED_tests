from mcap.reader import make_reader

with open(r"C:\Users\Leons\Downloads\rosbag_0.mcap", "rb") as f:
    reader = make_reader(f)
    summary = reader.get_summary()
    
    print(f"{'TOPIC':<65} | {'SCHEMA':<40} | MSGS")
    print("-" * 120)
    for channel in summary.channels.values():
        schema_name = summary.schemas[channel.schema_id].name if channel.schema_id else "unknown"
        # Count messages for this channel
        msg_count = sum(1 for sid, idx in summary.statistics.channel_message_counts.items() 
                       if sid == channel.id for _ in [idx])
        print(f"{channel.topic:<65} | {schema_name:<40} | {summary.statistics.channel_message_counts.get(channel.id, '?')}")