
import pypatchworkpp
import open3d as o3d
import numpy as np

# Laad je pointcloud
pcd = o3d.io.read_point_cloud("jouw_scan.pcd")
points = np.asarray(pcd.points)

# Patchwork++ instellen
params = pypatchworkpp.Parameters()
PatchworkPP = pypatchworkpp.patchworkpp(params)

# Ground segmentation uitvoeren
PatchworkPP.estimateGround(points)

# Resultaten ophalen
ground = PatchworkPP.getGround()
nonground = PatchworkPP.getNonground()