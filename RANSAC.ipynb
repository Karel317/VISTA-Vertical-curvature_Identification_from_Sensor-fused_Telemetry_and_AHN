    "        # Limit vmin/vmax to avoid outlier distortion\n",
    "        vmax = np.percentile(valid_vals, 95)\n",
    "        mesh.set_clim(0, max(vmax, 2.0))\n",
    "\n",
    "    # Labels and Title\n",
    "    cbar = plt.colorbar(mesh, ax=ax, pad=0.1)\n",
