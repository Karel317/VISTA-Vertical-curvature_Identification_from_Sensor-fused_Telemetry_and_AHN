import numpy as np
import os
import matplotlib.pyplot as plt

script_dir = os.path.dirname(os.path.abspath(__file__))
filename = os.path.join(script_dir, "Physical_meas_data.csv")

with open(filename, 'r') as f:
    labels = [h.strip() for h in f.readline().split(",")]

data = np.genfromtxt(filename, delimiter=",", skip_header=1, usecols=(0, 1, 2))
columns = []
n_columns = data.shape[1]
for i in range(n_columns):
    col = data[:, i] - data[0, i]
    col = col[~np.isnan(col)]
    columns.append(col)
cum_heights = [np.cumsum(columns[j]) for j in range(n_columns)]

fig, axes = plt.subplots(3, 1, figsize=(9, 9))
for i, (cum_height, ax) in enumerate(zip(cum_heights, axes)):
    x = np.arange(len(cum_height)) * 0.222
    ax.plot(x, -cum_height)
    ax.set_title(labels[i])
    ax.set_xlabel("Distance (m)")
    ax.set_ylabel("Cumulative height (cm)")
    ax.grid(True)

ax.set_xlabel("Distance (m)")
ax.set_ylabel("Height relative to first measurement (cm)")
ax.legend()
ax.grid(True)
plt.tight_layout()
plt.show()

